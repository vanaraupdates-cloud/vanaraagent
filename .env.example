# ============================================================
# AUTONOMOUS AI NEWS MEDIA SYSTEM — Environment Variables
# Copy this file to .env and fill in your credentials
# ============================================================

# --- AI CONTENT GENERATION (choose one) ---
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

AI_PROVIDER=gemini          # Options: gemini | openai | ollama
OLLAMA_MODEL=llama3.3       # Only used if AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# --- TWITTER / X ---
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Twitter posting mode: api | playwright | manual
TWITTER_MODE=api

# --- LINKEDIN ---
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# LinkedIn posting mode: api | manual
LINKEDIN_MODE=manual

# --- REDDIT (for research — free) ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AINewsAgent/1.0

# --- NEWS API (optional, enhances research) ---
NEWS_API_KEY=your_newsapi_key_here

# --- SYSTEM SETTINGS ---
DAILY_TWITTER_LIMIT=30
DAILY_LINKEDIN_LIMIT=30
TWITTER_POST_WINDOW_START=09:15
TWITTER_POST_WINDOW_END=16:00
LINKEDIN_POST_WINDOW_START=09:15
LINKEDIN_POST_WINDOW_END=16:00
RESEARCH_CYCLE_1=05:30
RESEARCH_CYCLE_2=12:15
ANALYTICS_PULL_TIME=16:00

# Minimum interval between posts (minutes)
POST_INTERVAL_MIN=22
POST_INTERVAL_MAX=47

# Dry run mode (no actual API calls)
DRY_RUN=false

# Dashboard port
DASHBOARD_PORT=3000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
